{
	"name": "bld",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"start": "vite dev --host --open",
		"dev": "vite dev",
		"dev:server": "echo \"Run ./dev-server.sh\"",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"lintd": "prettier --check . && eslint --debug .",
		"eslintd": "eslint --debug .",
		"format": "prettier --write --list-different .",
		"format:changed": "git diff --name-only main | xargs prettier --write --list-different",
		"l": "npm run format && npm run lint && npm run check"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.2",
		"@types/markdown-it": "^14.1.2",
		"@typescript-eslint/eslint-plugin": "^8.62.1",
		"autoprefixer": "^10.5.2",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"localforage": "^1.10.0",
		"postcss": "^8.5.16",
		"postcss-import": "^16.1.1",
		"prettier": "^3.9.3",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.0.0",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1",
		"vite": "^8.1.0",
		"zod": "^4.4.3"
	},
	"type": "module"
}
